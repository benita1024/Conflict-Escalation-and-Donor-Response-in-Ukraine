import csv
import asyncio
from datetime import datetime, timezone
from telethon import TelegramClient, functions, errors

# ================= CONFIGURATION =================
API_ID = []
API_HASH = []

# Search Keywords: Focused on Ukrainian compensation, payments, and aid
KEYWORDS = ['єВідновлення', 'виплати', 'допомога']

# Scraping Settings
LIMIT_PER_CHANNEL = 2000  
# =================================================


async def search_and_scrape():
    async with TelegramClient('research_session', API_ID, API_HASH) as client:
        all_found_channels = []

        # 1. Automated Search Phase
        print(f"[*] Starting automated search for keywords: {KEYWORDS}")
        for kw in KEYWORDS:
            try:
                result = await client(functions.contacts.SearchRequest(q=kw, limit=20))
            except Exception as e:
                print(f"[!] Error searching keyword {kw}: {e}")
                continue

            for chat in result.chats:
                if hasattr(chat, 'username') and chat.username:
                    all_found_channels.append(chat.username)

        # Remove duplicates
        target_list = list(dict.fromkeys(all_found_channels))
        print(f"[+] Search complete. Found {len(target_list)} potential target channels.")

        # 2. Deep Scraping Phase
        with open('ukraine_scam_master_data.csv', 'w', newline='', encoding='utf-8-sig') as f:
            writer = csv.writer(f)
            writer.writerow(['Channel', 'Message_ID', 'Date', 'Text', 'Views', 'Forwards'])

            for username in target_list:
                print(f"[*] Scraping: @{username}...")
                try:
                    count = 0
                    async for message in client.iter_messages(username, limit=LIMIT_PER_CHANNEL):
                        # Extract core text for NLP analysis
                        text = getattr(message, 'message', None) or getattr(message, 'text', None) or ''
                        if text:
                            # Clean text for CSV stability (remove newlines)
                            clean_text = text.replace('\n', ' ')
                            date_str = message.date.isoformat() if message.date else ''
                            
                            writer.writerow([
                                username, 
                                message.id, 
                                date_str,
                                clean_text, 
                                getattr(message, 'views', 0) or 0, 
                                getattr(message, 'forwards', 0) or 0
                            ])
                            count += 1
                    print(f"[V] @{username} complete. Scraped {count} messages.")

                except errors.FloodWaitError as e:
                    print(f"[!] Rate limit hit. Must wait {e.seconds} seconds.")
                    await asyncio.sleep(e.seconds)
                except Exception as e:
                    print(f"[X] Could not scrape @{username}: {e}")

        print("\n[DONE] All data has been saved to ukraine_scam_master_data.csv")


if __name__ == '__main__':
    asyncio.run(search_and_scrape())
